# stock-select 运行环境配置
# 复制此文件为 .env 并填入实际值
#
#   cp .env.example .env

# Tushare API token（用于获取行情数据）
TUSHARE_TOKEN=your_tushare_token_here

# PostgreSQL 连接 DSN（用于缓存和标签数据）
POSTGRES_DSN=postgresql://user:password@host:5432/stock_cache

# runtime 根目录，默认指向 skills/stock-select/runtime
STOCK_SELECT_RUNTIME_ROOT=runtime

# EOD prepared cache 最多保留数量；默认 30。盘中 .intraday. cache 不计入也不会被此设置清理。
# STOCK_SELECT_PREPARED_CACHE_LIMIT=30

# run record 默认关闭；填写筛选方法后，盘后 run 会写入 runtime/record.csv
# 多个方法用逗号分隔，例如：b2,lsh
# backfill runs 默认会把 STOCK_SELECT_RECORD_METHODS 覆盖为空，跳过记录
# 需要补 record.csv 时使用：stock-select-ml backfill records
# STOCK_SELECT_RECORD_METHODS=b2

# record.csv 保留最近 N 个入选交易日；开启 record 后未设置时默认 10
# STOCK_SELECT_RECORD_WINDOW_TRADING_DAYS=10

# 每次 run 或 review-list --record 调用 update_run_record 时最多写入排名前 N 条；未设置时默认 30
# STOCK_SELECT_RECORD_LIMIT=30
